<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Schedule a Visit | 4C Farm & Hatchery LLC</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>

<header class="site-header">
  <h1>4C Farm & Hatchery LLC</h1>
  <p>Small family-run chicken farm and hatchery in Rogers, Arkansas</p>

  <nav>
    <a href="index.html">Schedule a Visit</a>
    <a href="about.html">About 4C Farm</a>
    <a href="https://www.facebook.com/profile.php?id=61577346003231" target="_blank">Facebook</a>
  </nav>
</header>

<main class="container">

  <section class="card">
    <h2>View Available Visit Times</h2>
    <p>Please review available times on the 4C Farm calendar below. All visits are by request and must be confirmed by 4C Farm.</p>

    <div class="calendar-box">
      <iframe
        src="https://calendar.app.google/bwNrShVoAkK8fEkd7"
        title="4C Farm Scheduling Calendar"
        frameborder="0">
      </iframe>
    </div>
  </section>

  <section class="card">
    <h2>Request a Visit</h2>
    <p>Submit the form below to request a date and time. We will contact you to confirm availability.</p>

    <form name="visit-request" method="POST" data-netlify="true" action="/thanks.html">
      <input type="hidden" name="form-name" value="visit-request" />

      <label for="name">Name</label>
      <input type="text" id="name" name="name" required />

      <label for="email">Email</label>
      <input type="email" id="email" name="email" required />

      <label for="phone">Phone</label>
      <input type="tel" id="phone" name="phone" />

      <label for="date">Requested Date</label>
      <input type="date" id="date" name="requested-date" required />

      <label for="time">Requested Time</label>
      <input type="time" id="time" name="requested-time" required />

      <label for="visitors">Number of Visitors</label>
      <input type="number" id="visitors" name="number-of-visitors" min="1" />

      <label for="message">Message or Questions</label>
      <textarea id="message" name="message" rows="5"></textarea>

      <button type="submit">Submit Visit Request</button>
    </form>
  </section>

  <section class="card payment-section">
    <h2>Cash App Payment</h2>
    <p>Scan the QR code below to submit payment after your visit time has been confirmed.</p>

    <div class="qr-placeholder">
      <p>Cash App QR Code Placeholder</p>
      <p>Replace this box later with your QR code image.</p>
    </div>
  </section>

</main>

<footer>
  <p>4C Farm & Hatchery LLC | Rogers, AR | <a href="tel:14795504249">(479) 550-4249</a></p>
</footer>

</body>
</html>
